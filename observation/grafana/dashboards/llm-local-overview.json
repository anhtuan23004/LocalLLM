{
  "uid": "llm-local-overview",
  "title": "LLM-Local Overview",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "GPU Utilization %",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "nvidia_gpu_duty_cycle", "legendFormat": "GPU {{minor_number}}"}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 2,
      "title": "GPU Memory Used (MiB)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "nvidia_gpu_memory_used_bytes / 1024 / 1024", "legendFormat": "GPU {{minor_number}}"}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 3,
      "title": "vLLM Request Latency (p95)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{"expr": "histogram_quantile(0.95, rate(vllm:e2e_request_latency_seconds_bucket[5m]))", "legendFormat": "p95"}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 4,
      "title": "vLLM Tokens Generated/s",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{"expr": "rate(vllm:generation_tokens_total[1m])", "legendFormat": "tokens/s"}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 5,
      "title": "GPU Temperature (°C)",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
      "targets": [{"expr": "nvidia_gpu_temperature_celsius", "legendFormat": "GPU {{minor_number}}"}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 6,
      "title": "vLLM Running Requests",
      "type": "stat",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
      "targets": [{"expr": "vllm:num_requests_running", "legendFormat": "running"}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 7,
      "title": "vLLM Pending Requests",
      "type": "stat",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
      "targets": [{"expr": "vllm:num_requests_waiting", "legendFormat": "pending"}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 8,
      "title": "Ollama Up",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 24},
      "targets": [{"expr": "ollama_up", "legendFormat": "up"}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 9,
      "title": "Ollama Models",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 24},
      "targets": [{"expr": "ollama_models_total", "legendFormat": "available"}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    },
    {
      "id": 10,
      "title": "Ollama Loaded Models",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 24},
      "targets": [{"expr": "ollama_loaded_models_total", "legendFormat": "loaded"}],
      "datasource": {"type": "prometheus", "uid": "prometheus"}
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
