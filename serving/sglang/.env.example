# Local path to the models directory
MODEL_LOCAL_PATH=../../models

# Hugging Face cache and token for gated models
HF_CACHE_PATH=${HOME}/.cache/huggingface
# HF_TOKEN=your_token_here

# GPU Device IDs to use (e.g., "0", "0,1", "all")
CUDA_VISIBLE_DEVICES=0

# Ports
HOST_PORT=30000
CONTAINER_PORT=30000

# SGLang Model Configuration
SGLANG_IMAGE_TAG=latest
SGLANG_MODEL_PATH=/models/GLM-OCR
SGLANG_TP_SIZE=1
SGLANG_MEM_FRACTION_STATIC=0.8
SGLANG_EXTRA_ARGS=

