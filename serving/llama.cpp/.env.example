# Local path to the models directory
MODEL_LOCAL_PATH=../../models

# Ports
HOST_PORT=18080
CONTAINER_PORT=8080

# llama.cpp server image
# Use server for CPU, server-cuda for NVIDIA GPU.
LLAMA_CPP_IMAGE_TAG=server-cuda

# GGUF model path inside the container.
LLAMA_CPP_MODEL_PATH=/models/model.gguf
LLAMA_CPP_CTX_SIZE=4096
LLAMA_CPP_N_PARALLEL=2
LLAMA_CPP_N_GPU_LAYERS=99
LLAMA_CPP_EXTRA_ARGS=
