# Open WebUI image
OPEN_WEBUI_IMAGE_TAG=v0.6.15

# Ports
HOST_PORT=18088
CONTAINER_PORT=8080

# UI identity and auth.
# Keep WEBUI_AUTH=true outside disposable local demos.
WEBUI_NAME=LLM-Local
WEBUI_AUTH=true
WEBUI_SECRET_KEY=sk-local-open-webui

# Open WebUI should use LiteLLM as its only model provider in this repo.
ENABLE_OLLAMA_API=false
ENABLE_OPENAI_API=true
OPENAI_API_BASE_URL=http://litellm:4000/v1
OPENAI_API_KEY=sk-local-litellm
