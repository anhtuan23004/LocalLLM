HOST_PORT=18092
CONTAINER_PORT=8092

# LiteLLM gateway reachable from this container on llm-net.
LITELLM_BASE_URL=http://litellm:4000/v1
LITELLM_API_KEY=sk-local-litellm

# Required LiteLLM Gateway Alias for OCR v1.
LITELLM_MODEL=

# File and PDF processing limits.
REQUEST_TIMEOUT_SECONDS=120
MAX_FILE_BYTES=52428800
MAX_PDF_PAGES=20
PDF_RENDER_DPI=144
        
